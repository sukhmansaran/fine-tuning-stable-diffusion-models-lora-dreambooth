# ── Auth ─────────────────────────────────────────────────────────────────────
# Set a secret key to protect the API. Leave empty to disable auth (local dev).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── Base model ────────────────────────────────────────────────────────────────
# Path to the base Stable Diffusion model in diffusers format.
# Download: huggingface-cli download SG161222/Realistic_Vision_V5.1_noVAE --local-dir ./models/base
MODEL_PATH=./models/base

# ── Output ────────────────────────────────────────────────────────────────────
# Where LoRA checkpoints are saved after training.
OUTPUT_DIR=./outputs/lora

# ── Optional: pre-load existing LoRA weights on startup ──────────────────────
# Leave empty to train from scratch via the UI.
LORA_PATH=

# ── LoRA settings (only used when LORA_PATH is set) ──────────────────────────
LORA_RANK=4
LORA_ALPHA=8
DUAL_PHASE=false
TRIGGER_WORD=
